<% layout('/layouts/boilerplate.ejs') -%>
.<div class="row mt-3">
    <h1 class="col-6 offset-3">Login on wanderlust</h1>
  <div class="col-6 offset-3">
    <form action="/login" method="POST">
         <div class="mb-3">
         <label for="username" class="form-label" class="needs-validation" novalidate>Username</label>
      <input name="username"
      id="username" 
      type="text"  
      class="form-control"
      required
      />
      <div class="valid-feedback">Username looks good</div>
        </div>
         
             <div class="mb-3">
                 <label for="password" class="form-label">Password</label>    
            <input name="password"
      id="password" 
      type="password"  
      class="form-control"
      required
      />
        <div class="valid-feedback">Password looks good</div>
            </div>
        <button type="submit" class="btn btn-success">Login</button>
    </form>
  </div>
</div>
     